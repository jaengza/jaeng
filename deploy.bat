@echo off
chcp 65001 > nul
title ApexTrader Pro - GitHub Pages Deployer v3.4
color 0B

echo =====================================================================
echo    ApexTrader Pro — GitHub Pages Ultimate Deployer v3.4
echo =====================================================================
echo.
echo สวัสดีครับคุณเทรดเดอร์! ผมได้จัดเตรียมความพร้อมและเซ็ตระบบ Git 
echo ในเครื่องของท่านเรียบร้อยแล้วในทุกจุดครับ
echo.
echo ตอนนี้โค้ดทั้งหมด (ApexTrader Pro v3.4) ถูกบันทึกเข้าสู่ Git เรียบร้อยแล้ว
echo และพร้อมที่จะอัปโหลดขึ้นเซิร์ฟเวอร์ของ GitHub ของท่านแล้วครับ!
echo.
echo ---------------------------------------------------------------------
echo 💡 สิ่งที่ท่านต้องทำตอนนี้:
echo 1. เข้าเว็บ GitHub.com ล็อกอินบัญชีของท่าน
echo 2. กดสร้าง Repository ใหม่ (ตั้งชื่อ เช่น "jaeng" หรือชื่ออื่น ๆ)
echo 3. **เลือกตั้งค่าเป็น Public (สาธารณะ)**
echo 4. คัดลอกลิงก์ Repository URL ที่ได้มา (เช่น https://github.com/ชื่อของท่าน/jaeng.git)
echo ---------------------------------------------------------------------
echo.

:ask_url
set /p giturl="👉 กรุณาวางลิงก์ GitHub Repository URL ของท่านที่นี่ แล้วกด Enter: "

if "%giturl%"=="" (
    echo.
    echo ❌ ข้อผิดพลาด: ลิงก์ URL ไม่สามารถปล่อยว่างได้ครับ กรุณาลองใหม่อีกครั้ง
    goto ask_url
)

echo.
echo ⏳ กำลังเตรียมการอัปโหลดไฟล์ไปยัง GitHub...
echo.

:: ลบ remote origin เก่าหากมีอยู่
git remote remove origin >nul 2>&1

:: เพิ่ม remote origin ใหม่
git remote add origin %giturl%
if errorlevel 1 (
    echo ❌ เกิดข้อผิดพลาดในการเชื่อมโยงลิงก์ URL กรุณาตรวจสอบลิงก์อีกครั้งครับ
    pause
    exit /b
)

:: ตั้งชื่อสาขาหลักเป็น main
git branch -M main

echo 🚀 กำลังอัปโหลดไฟล์ (Push) ขึ้นเซิร์ฟเวอร์ GitHub...
echo 💡 หมายเหตุ: ระบบของ Windows จะเด้งหน้าต่างขึ้นมาให้ท่านกดยืนยันตัวตน (Login)
echo    กรุณากดล็อกอินเพื่ออนุญาตความปลอดภัยในการอัปโหลดไฟล์ครับ
echo.

git push -u origin main

if errorlevel 1 (
    echo.
    echo ❌ อัปโหลดไม่สำเร็จ! กรุณาตรวจสอบว่า:
    echo 1. ลิงก์ URL ของ Repository ถูกต้องหรือไม่
    echo 2. ท่านได้กดยืนยันตัวตนในหน้าต่างเบราว์เซอร์สำเร็จแล้วหรือไม่
    echo 3. มีสิทธิ์การแก้ไข Repository ดังกล่าวจริงหรือไม่
    echo.
    pause
    goto ask_url
)

echo.
echo =====================================================================
echo 🎉 ยินดีด้วยครับ! อัปโหลดไฟล์ขึ้น GitHub Pages สำเร็จเรียบร้อยแล้ว! 🎉
echo =====================================================================
echo.
echo 🌐 ขั้นตอนสุดท้ายในการเปิดหน้าเว็บออนไลน์จริง:
echo 1. เปิดหน้าเว็บ Repository ของท่านบน GitHub
echo 2. คลิกเข้าไปที่แท็บ Settings (รูปฟันเฟืองด้านบน)
echo 3. แถบเมนูด้านซ้าย เลือกที่หัวข้อ Pages (อยู่ใต้ปุ่มหัวข้อ Code and automation)
echo 4. ภายใต้หัวข้อ Build and deployment ตรง Branch:
echo    เปลี่ยนจาก None เป็น main แล้วกด Save สีน้ำเงินข้าง ๆ ครับ
echo 5. รอประมาณ 1 นาที เว็บของท่านจะออนไลน์จริงทันทีครับ!
echo.
echo 🌟 ลิงก์เว็บเทรดของท่านจะอยู่ที่นี่:
echo 👉 https://[ชื่อบัญชีของท่าน].github.io/[ชื่อโปรเจกต์ที่ตั้ง]/
echo.
echo ขอให้ท่านมีความสุขกับการเทรดและการใช้เครื่องมือวิเคราะห์ครับ!
echo =====================================================================
echo.
pause
